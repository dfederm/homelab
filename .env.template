####################
# Common
# Values here are typically set in common.env (shared across machines).
# Machine-specific env files can override any value.
####################
TZ=

# Comma-separated list of services to deploy on this machine (order matters)
HOMELAB_SERVICES=

# Space-separated list of setup modules to run on this machine
# Available: configure-amdgpu, configure-pi-kiosk, configure-scrutiny-collector,
#            configure-smb-mount, configure-ssh, configure-storage-alerts,
#            configure-storage-health, create-lxcs, create-vms, create-users,
#            install-beszel-agent, install-docker, install-samba,
#            install-tools, set-share-permissions
HOMELAB_SETUP_MODULES=

####################
# Users & Groups (machines needing user/group alignment)
####################

# Space-separated prefixes for role groups
# Each prefix requires: _GID
# Group name is derived by lowercasing the prefix.
# e.g. HOMELAB_GROUPS="ADULTS KIDS" with ADULTS_GID=1100
HOMELAB_GROUPS=

# Space-separated prefixes for user definitions
# Each prefix requires: _UID, _GROUPS (comma-separated group names)
# Optional per prefix: _SERVICE=1 marks a service account (in a group for
#   permissions only) — created normally, but gets NO personal share folder and
#   is a valid user only of the admin infrastructure shares, not the family shares.
# Username is derived by lowercasing the prefix.
# A primary group with matching name and GID is created automatically.
# e.g. HOMELAB_USERS="ALICE BOB" with ALICE_UID=1001, ALICE_GROUPS="adults,family"
HOMELAB_USERS=

####################
# SSH
####################

# Optional: explicit path to authorized_keys file.
# Defaults to <config_dir>/authorized_keys (next to machine .env files).
SSH_AUTHORIZED_KEYS_FILE=

####################
# Network
####################
NETWORK_ROUTER_IP=
NETWORK_PREFIX=24

# DNS for LXC containers. Use the router, not AdGuard, so LXCs have DNS
# even when AdGuard is down or not yet deployed.
DNS_IP=

# Full subnet in CIDR notation (used by macvlan for AdGuard Home)
NETWORK_SUBNET=

####################
# ZFS / Storage
####################
ZFS_POOL=

# --- Storage health (host-level: ZFS scrub + SMART self-tests) ---
# Used by the configure-storage-health module (runs on the Proxmox host).
# These ship with recommended defaults below. Each scheduled feature is gated by
# its value: CLEAR a value (set it empty) to disable that specific feature.

# systemd OnCalendar for the ZFS scrub. Empty = no scheduled scrub.
# Default: first Sunday of the month at 03:00.
ZFS_SCRUB_SCHEDULE="Sun *-*-01..07 03:00:00"

# systemd OnCalendar for the daily ZFS pool health check. Empty = disabled.
ZFS_HEALTH_CHECK_SCHEDULE="*-*-* 08:00:00"

# smartd `-s` self-test schedule regex (see smartd.conf(5)). Empty = no scheduled
# self-tests (smartd still monitors/logs drive health).
# Default: short test daily 02:00, long test monthly on the 15th at 03:00.
# (Long tests are slow on large drives — tens of hours on a multi-TB drive — so monthly,
#  not weekly, keeps the background load sane while still exercising the surface.)
SMART_SELFTEST_SCHEDULE="(S/../.././02|L/../15/./03)"

# --- LXC thin-pool reclaim (host-level: weekly pct fstrim) ---
# Used by the configure-lxc-fstrim module (runs on the Proxmox host). systemd
# OnCalendar for trimming LXC rootfs volumes so blocks freed inside containers
# return to the LVM thin pool. Empty = disabled (timer removed). VMs reclaim
# separately via discard=on (see create-vms). Default: weekly.
LXC_FSTRIM_SCHEDULE=weekly

