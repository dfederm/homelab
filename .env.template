####################
# Minecraft (Bedrock)
####################
# Multiple Bedrock worlds are supported, each a separate server instance deployed from
# the same services/minecraft compose. Add a world by adding its name here and creating a
# matching per-world env file — no repo change needed.

# Space-separated list of world/instance names (lowercase). Each name <w> deploys a
# container "minecraft-<w>" and reads per-world settings from <config_dir>/minecraft/<w>.env.
MINECRAFT_INSTANCES="creative survival"

# --- Family-wide settings (shared by all worlds; a per-world file may override) ---
# Restrict joins to an allow list (recommended "true" for a private server). When true,
# only players listed in MINECRAFT_ALLOW_LIST_USERS may join.
MINECRAFT_ALLOW_LIST=true
# Allowed players, comma- or newline-separated. Use gamertag:xuid pairs, or a bare gamertag
# (resolved to an XUID at startup). e.g. "Player1:2535000000000000,Player2:2535111111111111"
MINECRAFT_ALLOW_LIST_USERS=
# Server operators (admins): comma-separated gamertags or XUIDs. Prefer XUIDs — they're
# immutable and need no startup lookup. Document a gamertag on its OWN line above the value;
# an inline "# comment" is not reliably stripped by docker compose --env-file. e.g.:
#   # SomeGamerTag
#   MINECRAFT_OPS=2535000000000000
MINECRAFT_OPS=

####################
# BedrockConnect (console world menu)
####################
# Lets game consoles (Xbox/PlayStation/Switch) reach the Bedrock worlds. Consoles can't
# enter an arbitrary server IP, so a "featured server" hostname is DNS-redirected (an AdGuard
# rewrite) to this host on UDP 19132, and BedrockConnect shows an in-game menu of the worlds.

# Directory on the NAS containing the menu file custom_servers.json (a JSON array listing
# each world as {name, address, port}); mounted read-only into the container. See
# services/bedrock-connect/custom_servers.example.json for the format.
BEDROCK_CONNECT_CONFIG=

####################
# Monitoring (hub - runs on one host only)
####################
BESZEL_WEB_PORT=
UPTIME_KUMA_WEB_PORT=

####################
# Monitoring Agent
####################
# The agent runs as a Docker container (services/monitoring-agent) on hosts that
# run Docker, and natively (install-beszel-agent module) on hosts that don't
# (the Proxmox host and the NAS LXC). All agents share BESZEL_AGENT_KEY.
# The native binary version is derived from the henrygd/beszel-agent image tag in
# services/monitoring-agent/docker-compose.yml (Renovate's single source of truth)
# - there is no separate version var to keep in sync.
BESZEL_AGENT_PORT=
BESZEL_AGENT_KEY=

# Native agent only (install-beszel-agent module), optional, per-host:
# comma-separated extra mountpoints to monitor beyond root. Use "path__Name" to
# set a friendly display name. On the Proxmox host this is how the ZFS datasets
# are surfaced, e.g.:
#   BESZEL_AGENT_EXTRA_FILESYSTEMS="/tank/data__data,/tank/media__media"
BESZEL_AGENT_EXTRA_FILESYSTEMS=

####################
# Alerting
####################
# Shared alert channel for ALL alert sources (Beszel hub, the storage-space check,
# and scrutiny) - ONE Shoutrrr URL so every source notifies the same place.
# Backend: Pushover. Build the URL from your Pushover application API token and
# your user key (do NOT commit a real one - secrets live in env files, and this
# repo is public):
#   pushover://shoutrrr:<APP_TOKEN>@<USER_KEY>/
# Leave blank to keep alerts syslog-only (safe) until you set it. Any other
# Shoutrrr URL works too if you ever switch backends (ntfy://..., gotify://...).
HOMELAB_ALERT_SHOUTRRR_URL=

####################
# Storage-space alerts (configure-storage-alerts module, Proxmox host)
####################
# LVM thin pool to monitor (backs all LXC rootfs + VM disks).
STORAGE_ALERT_THINPOOL=pve/data
# Alert when the thin pool data% exceeds this.
STORAGE_ALERT_THINPOOL_PERCENT=80
# Alert when the ZFS pool (ZFS_POOL) capacity% exceeds this.
STORAGE_ALERT_ZPOOL_PERCENT=85
# Minimum hours between repeat alerts for the same metric (anti-spam).
STORAGE_ALERT_COOLDOWN_HOURS=12

