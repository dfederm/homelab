####################
# Common
# Values here are typically set in common.env (shared across machines).
# Machine-specific env files can override any value.
####################
TZ=

# Comma-separated list of services to deploy on this machine (order matters)
HOMELAB_SERVICES=

# Space-separated list of setup modules to run on this machine
# Available: configure-amdgpu, configure-ssh, create-lxcs, create-vms, create-users,
#            install-docker, install-samba, install-tools, set-share-permissions
HOMELAB_SETUP_MODULES=

####################
# Users & Groups (machines needing user/group alignment)
####################

# Space-separated prefixes for role groups
# Each prefix requires: _GID
# Group name is derived by lowercasing the prefix.
# e.g. HOMELAB_GROUPS="ADULTS KIDS" with ADULTS_GID=1100
HOMELAB_GROUPS=

# Space-separated prefixes for user definitions
# Each prefix requires: _UID, _GROUPS (comma-separated group names)
# Username is derived by lowercasing the prefix.
# A primary group with matching name and GID is created automatically.
# e.g. HOMELAB_USERS="ALICE BOB" with ALICE_UID=1001, ALICE_GROUPS="adults,family"
HOMELAB_USERS=

####################
# SSH
####################

# Optional: explicit path to authorized_keys file.
# Defaults to <config_dir>/authorized_keys (next to machine .env files).
SSH_AUTHORIZED_KEYS_FILE=

####################
# Network
####################
NETWORK_ROUTER_IP=
NETWORK_PREFIX=24

# DNS for LXC containers. Use the router, not AdGuard, so LXCs have DNS
# even when AdGuard is down or not yet deployed.
DNS_IP=

# Full subnet in CIDR notation (used by macvlan for AdGuard Home)
NETWORK_SUBNET=

####################
# ZFS / Storage
####################
ZFS_POOL=

####################
# Proxmox Host
####################

# Space-separated env var prefixes for LXC definitions
# e.g. "DOCKER_LXC NAS_LXC"
# Each prefix requires: _VMID, _HOSTNAME, _IP, _MEMORY_MIB, _CORES,
#   _ROOTFS_GIB, _NESTING, _MP0 (and optionally _MP1, _MP2, ...)
HOMELAB_LXCS=

# Space-separated env var prefixes for VM definitions
# e.g. "HAOS_VM"
# Each prefix requires: _VMID, _HOSTNAME, _MEMORY_MIB, _CORES
# Optional: _BIOS (seabios), _MACHINE (i440fx), _OSTYPE (l26), _AGENT (0)
# Optional: _IMAGE (path to disk image file, imported on first create only)
# Optional: _IP (informational only, not passed to qm)
HOMELAB_VMS=

# Docker LXC
DOCKER_LXC_VMID=
DOCKER_LXC_HOSTNAME=
DOCKER_LXC_IP=
DOCKER_LXC_MEMORY_MIB=
DOCKER_LXC_CORES=
DOCKER_LXC_ROOTFS_GIB=
DOCKER_LXC_NESTING=
# Bind mounts: <zfs_dataset>,mp=<container_path>
DOCKER_LXC_MP0=
DOCKER_LXC_MP1=
DOCKER_LXC_MP2=
# Set to 1 to pass through /dev/dri for hardware transcoding (VAAPI)
DOCKER_LXC_GPU=

# NAS LXC
NAS_LXC_VMID=
NAS_LXC_HOSTNAME=
NAS_LXC_IP=
NAS_LXC_MEMORY_MIB=
NAS_LXC_CORES=
NAS_LXC_ROOTFS_GIB=
NAS_LXC_NESTING=
NAS_LXC_MP0=
NAS_LXC_MP1=
NAS_LXC_MP2=

# Home Assistant VM
HAOS_VM_VMID=
HAOS_VM_HOSTNAME=
HAOS_VM_IP=
HAOS_VM_MEMORY_MIB=
HAOS_VM_CORES=
HAOS_VM_BIOS=ovmf
HAOS_VM_MACHINE=q35
HAOS_VM_OSTYPE=l26
HAOS_VM_AGENT=1
# Path to disk image file on ZFS (imported on first create only)
HAOS_VM_IMAGE=

####################
# Docker Host
####################

# Where to store persistent application data
DOCKER_APPDATA_ROOT=

# Path to the homelab repo clone (used by webhook CI/CD for volume mount)
REPO_DIR=

# Path to the config directory containing env files (used by webhook CI/CD)
CONFIG_DIR=

# IP address of the Docker host (for LAN service URLs)
DOCKER_HOST_IP=

# Network interface of host machine
NETWORK_INTERFACE=

####################
# NAS (Samba)
####################

# Root path of the file share
SHARE_ROOT=

# Optional: name for a root-level SMB share exposing SHARE_ROOT (adults only)
SMB_ROOT_SHARE=

# Optional: path to media library (creates admin-only SMB share)
SMB_MEDIA_PATH=

# Optional: path to homelab data (creates admin-only SMB share)
SMB_HOMELAB_PATH=

####################
# Adguard Home
####################
ADGUARDHOME_IP=
ADGUARDHOME_WEB_PORT=

####################
# Backup
####################
# Root directory containing user backup source directories
BACKUP_DATA_ROOT=
# Space-separated list of source=dest pairs (e.g. "Alice=onedrivealice:/backup Bob=onedrivebob:/backup")
BACKUP_TARGETS=

####################
# Dozzle
####################
DOZZLE_WEB_PORT=

####################
# Forgejo
####################
FORGEJO_FQDN=
FORGEJO_HTTP_PORT=
FORGEJO_SSH_PORT=

####################
# Files
####################
FILES_HTTP_PORT=
FILES_FQDN=
FILES_OFFICE_HTTP_PORT=
FILES_OFFICE_FQDN=

####################
# Homepage
####################
HOMEPAGE_WEB_PORT=

####################
# Home Assistant
####################
HOMEASSISTANT_FQDN=
HOMEASSISTANT_IP=
HOMEASSISTANT_HTTP_PORT=

####################
# Jellyfin
####################
JELLYFIN_FQDN=
JELLYFIN_MEDIA_LOCATION=
JELLYFIN_HTTP_PORT=
JELLYFIN_CLIENT_DISCOVERY_PORT=

####################
# Monitoring
####################
BESZEL_WEB_PORT=
# Agent key — set after first hub setup (copy from hub UI when adding a system)
BESZEL_AGENT_KEY=
UPTIME_KUMA_WEB_PORT=

####################
# Photos
####################
PHOTOS_FQDN=
PHOTOS_HTTP_PORT=

# Where pictures are stored. Intent is to use as an external library.
IMMICH_PICTURES_LOCATION=

# The location where uploaded files are stored. Note: We don't really use this.
IMMICH_UPLOAD_LOCATION=

IMMICH_DB_NAME=immich
IMMICH_DB_USERNAME=
IMMICH_DB_PASSWORD=

####################
# Webhook
####################

# Port for the webhook listener
WEBHOOK_HTTP_PORT=

# Domain for external access (routed through Caddy)
WEBHOOK_FQDN=

# HMAC-SHA256 shared secret (must match GitHub webhook configuration)
WEBHOOK_SECRET=

# Path to SSH deploy key file (on the Docker LXC filesystem)
# Used by deploy.sh to SSH into remote machines for deployments.
DEPLOY_KEY_PATH=

# Space-separated prefixes for remote machines that receive deployments.
# Each prefix requires: _DEPLOY_HOST
# e.g. HOMELAB_DEPLOY_TARGETS="PROXMOX_HOST PI"
HOMELAB_DEPLOY_TARGETS=

# Example remote machines:
# PROXMOX_HOST_DEPLOY_HOST=192.168.1.x
# PI_DEPLOY_HOST=192.168.1.y

####################
# ZWAVE
####################

ZWAVE_SESSION_SECRET=

# Hostname or IP of the machine running Z-Wave
ZWAVE_HOST=

# Do not use /dev/ttyUSBX serial devices, as those mappings can change over time.
# Instead, use the /dev/serial/by-id/X serial device for your Z-Wave stick.
ZWAVE_DEVICE=

# Port for web interface
ZWAVE_WEB_PORT=

# Port for Z-Wave JS websocket server
ZWAVE_WS_PORT=
