####################
# AI (Ollama + Open WebUI)
####################
# Host port mapped to the Ollama API (container port 11434). Ollama has no auth, so
# this is for internal Docker network / LAN use only — never expose it publicly.
OLLAMA_HTTP_PORT=

# Space-separated list of models pulled automatically on deploy by the ollama-pull
# container (idempotent — already-present models are skipped). Leave blank to pull
# nothing. qwen3:30b = chat, qwen2.5:7b = small/fast tasks, nomic-embed-text = embeddings.
OLLAMA_PULL_MODELS="qwen3:30b qwen2.5:7b nomic-embed-text"

OPEN_WEBUI_FQDN=
# Host port mapped to the Open WebUI server (container port 8080).
OPEN_WEBUI_HTTP_PORT=
# Small/fast model used for Open WebUI background tasks (title/tag/query generation) so the
# large chat model isn't burned on trivia. Must be one of OLLAMA_PULL_MODELS.
OPEN_WEBUI_TASK_MODEL="qwen2.5:7b"
# Embeddings model Open WebUI uses for RAG (via the local Ollama). Must be one of
# OLLAMA_PULL_MODELS.
OPEN_WEBUI_RAG_EMBEDDING_MODEL="nomic-embed-text"

####################
# Backup
####################
# Root directory containing the per-target backup source directories
BACKUP_DATA_ROOT=
# Multiple backup targets are supported, each a separate rclone container deployed from the
# same services/backup compose. Add a target by adding its name here and creating a matching
# per-target env file — no repo change needed.

# Space-separated list of target names (lowercase). Each name <t> deploys a container
# "backup-<t>" that syncs one source dir under BACKUP_DATA_ROOT to a cloud destination,
# reading its settings (BACKUP_SOURCE_DIR, BACKUP_DEST, optional BACKUP_CRON) from
# <config_dir>/backup/<t>.env (copy services/backup/backup.env.example).
# Each target's BACKUP_DEST must be a DISJOINT remote:path (the sync prunes its dest; enforced at
# deploy by services/backup/pre-up.sh). Shared folders with no single owner (e.g. family, adults)
# can back up into a personal remote under a separate top-level path, e.g. a "family" target ->
# onedrivealice:/nas-backup-shared/family.
BACKUP_INSTANCES="alice bob"

# Absolute path to the shared rclone config dir (the backup containers' /config/rclone mount,
# i.e. ${DOCKER_APPDATA_ROOT}/backup/rclone). When set, the install-samba module (on the NAS)
# keeps it admin-editable over SMB — owned root:admin with a default ACL, and rclone.conf
# normalized to 660 — even though the rclone container also writes it (it rotates OAuth tokens
# back in). Set this in the NAS machine env file (where SMB_HOMELAB_PATH is defined), e.g.
# ${SMB_HOMELAB_PATH}/appdata/backup/rclone. Leave blank to skip (the dir stays as the
# container creates it, root:root).
BACKUP_RCLONE_CONFIG_DIR=

