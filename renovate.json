{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "docker:pinDigests",
    ":dependencyDashboard"
  ],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "description": "Check for Docker image updates weekly",
      "matchDatasources": [
        "docker"
      ],
      "schedule": [
        "before 6am on monday"
      ]
    },
    {
      "description": "Don't update dependencies managed by upstream app authors",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/immich-app/postgres",
        "docker.io/valkey/valkey",
        "collabora/code"
      ],
      "enabled": false
    },
    {
      "description": "Group Beszel hub and agent updates together",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "/^henrygd\\/beszel/"
      ],
      "groupName": "beszel"
    },
    {
      "description": "Scrutiny only supports InfluxDB 2.x — do not bump to 3.x",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "influxdb"
      ],
      "allowedVersions": "/^2\\./"
    },
    {
      "description": "Vikunja's Postgres: stay on major 18 — a Postgres major upgrade needs a manual pg_upgrade/dump-restore and must not be automated (would break the data directory)",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "postgres"
      ],
      "allowedVersions": "<19"
    }
  ],
  "docker-compose": {
    "managerFilePatterns": [
      "/services/.+/docker-compose\\.yml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep the pinned shoutrrr CLI version (configure-storage-alerts module) updated via PRs, like the Docker images",
      "managerFilePatterns": [
        "/scripts/setup/modules/configure-storage-alerts\\.sh$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+SHOUTRRR_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "extractVersionTemplate": "^v(?<version>.+)$",
      "versioningTemplate": "semver"
    }
  ]
}
