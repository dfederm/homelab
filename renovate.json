{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "docker:pinDigests",
    ":dependencyDashboard"
  ],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "description": "Check for Docker image updates daily",
      "matchDatasources": [
        "docker"
      ],
      "schedule": [
        "before 6am"
      ]
    },
    {
      "description": "Don't update dependencies managed by upstream app authors",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/immich-app/postgres",
        "docker.io/valkey/valkey",
        "collabora/code"
      ],
      "enabled": false
    }
  ],
  "docker-compose": {
    "managerFilePatterns": [
      "/services/.+/docker-compose\\.yml$/"
    ]
  }
}
