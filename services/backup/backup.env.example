# Template for a backup target. Copy this to <config_dir>/backup/<name>.env and edit,
# then add "<name>" to BACKUP_INSTANCES in the machine env file. No repo change needed.

# Source directory to back up, relative to BACKUP_DATA_ROOT (mounted read-only).
BACKUP_SOURCE_DIR=Alice
# rclone destination ("remote:path"). The remote must exist in the shared rclone config
# (${DOCKER_APPDATA_ROOT}/backup/rclone).
#
# IMPORTANT: the sync MIRRORS this exact path and PRUNES anything under it that isn't in the
# source, so each target's dest must be DISJOINT from every other target's dest. Two targets
# may share one remote only if they point at non-overlapping paths under it — e.g. a shared
# folder backed up into a person's drive must use a separate top-level path, not a subpath of
# that person's own backup:
#   personal:  BACKUP_DEST=onedrivealice:/nas-backup
#   shared:    BACKUP_DEST=onedrivealice:/nas-backup-shared/family   # NOT onedrivealice:/nas-backup/...
# This is enforced at deploy: services/backup/pre-up.sh aborts run-service if two targets' dests
# overlap on the same remote.
BACKUP_DEST=onedrivealice:/nas-backup
# Optional cron schedule for the recurring backup (default "0 3 * * *"). Stagger the minute
# across targets so they don't all run at once and contend on the shared rclone config —
# especially targets that share a remote (they write the same OAuth token back). e.g.:
#BACKUP_CRON=15 3 * * *
