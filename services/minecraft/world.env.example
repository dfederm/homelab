# Template for a Minecraft world. Copy this to <config_dir>/minecraft/<name>.env and edit,
# then add "<name>" to MINECRAFT_INSTANCES in the machine env file. No repo change needed.
# (Family-wide settings like MINECRAFT_OPS / MINECRAFT_ALLOW_LIST live in the machine env.)

# Unique UDP port published on the Docker host (must differ from every other world).
MINECRAFT_PORT=19133
# Name shown in the BedrockConnect menu.
MINECRAFT_SERVER_NAME=My World
# World folder under /data/worlds (created fresh on first start).
MINECRAFT_LEVEL_NAME=myworld
# survival | creative | adventure
MINECRAFT_GAMEMODE=survival
# peaceful | easy | normal | hard
MINECRAFT_DIFFICULTY=easy
# Required for gamerules. Harmless on a dedicated server (achievements already off in multiplayer).
MINECRAFT_ALLOW_CHEATS=true

# Optional: per-world gamerules go in a sibling file <name>.init (one command per line), e.g.:
#   gamerule keepInventory true