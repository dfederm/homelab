# Jellyfin - Media streaming
{$JELLYFIN_FQDN} {
	reverse_proxy localhost:{$JELLYFIN_HTTP_PORT}
}

# Immich - Photo management
{$PHOTOS_FQDN} {
	reverse_proxy localhost:{$PHOTOS_HTTP_PORT}
}

# Filestash - Web file manager
{$FILES_FQDN} {
	# Block admin panel from external access
	handle /admin/* {
		respond "Denied" 403
	}
	handle {
		reverse_proxy localhost:{$FILES_HTTP_PORT}
	}
}

# Collabora Online - Document editing
{$FILES_OFFICE_FQDN} {
	reverse_proxy localhost:{$FILES_OFFICE_HTTP_PORT}
}

# Home Assistant - Smart home
{$HOMEASSISTANT_FQDN} {
	reverse_proxy {$HOMEASSISTANT_IP}:{$HOMEASSISTANT_HTTP_PORT}
}

# Forgejo - Git hosting
{$FORGEJO_FQDN} {
	reverse_proxy localhost:{$FORGEJO_HTTP_PORT}
}

# Webhook - CI/CD deployment trigger
{$WEBHOOK_FQDN} {
	rewrite * /hooks{uri}
	reverse_proxy localhost:{$WEBHOOK_HTTP_PORT}
}

# Open WebUI - AI chat frontend (Ollama has no block — it stays internal-only)
{$OPEN_WEBUI_FQDN} {
	reverse_proxy localhost:{$OPEN_WEBUI_HTTP_PORT}
}

# Vikunja - Task management
{$VIKUNJA_FQDN} {
	reverse_proxy localhost:{$VIKUNJA_HTTP_PORT}
}

# Radicale - CalDAV/CardDAV (calendar + contacts). The .well-known redirects let clients
# auto-discover the DAV root from the bare domain (e.g. iOS adding a CalDAV account with just
# the server hostname).
{$RADICALE_FQDN} {
	redir /.well-known/carddav / permanent
	redir /.well-known/caldav / permanent
	reverse_proxy localhost:{$RADICALE_HTTP_PORT}
}
